app:
  name: "structalert"
  env: "local"

logging:
  level: "INFO"
  directory: "../logs"

databases:
  source:
    host: "127.0.0.1"
    port: 3306
    user: "root"
    password: "change_me"
    database: "serviceordercenter"
    charset: "utf8mb4"
    connect_timeout: 10
    read_timeout: 30
    write_timeout: 30
    max_connections: 10
  his:
    host: "127.0.0.1"
    port: 3307
    user: "root"
    password: "change_me"
    database: "serviceordercenter_his"
    charset: "utf8mb4"
    connect_timeout: 10
    read_timeout: 30
    write_timeout: 30
    max_connections: 10
  cfg:
    host: "127.0.0.1"
    port: 3308
    user: "root"
    password: "change_me"
    database: "serviceordercenter"
    charset: "utf8mb4"
    connect_timeout: 10
    read_timeout: 30
    write_timeout: 30
    max_connections: 10

wecom:
  webhook_key: ""

# =============================================================================
# 三大能力（启动时由 structalert.pipelines_config 展开为 schedule_set / sync 等）
# =============================================================================
pipelines:
  struct_compare:
    schedule:
      job_id: daily_struct_compare
      enabled: true
      cron: "0 2 * * *"
      module: "structalert.tasks"
      function: "run_daily_comparison"

  base_data_sync:
    schedule:
      job_id: weekly_data_sync
      enabled: true
      cron: "0 3 * * 0"
      module: "structalert.tasks"
      function: "run_weekly_sync"
    sync:
      days_before: null
      batch_size: 500
      concurrency: 2
      dry_run: true

  special_tables_sync:
    schedule:
      job_id: workorder_archive_sync
      enabled: false
      cron: "45 3 * * *"
      module: "structalert.tasks"
      function: "run_workorder_archive_sync"
    enabled: false
    dry_run: true
    window_days_per_run: 7
    skip_if_struct_diff: true
    state_table: "cfg_business_sync_state"
    delete_log_table: "cfg_business_sync_delete_log"
    batch_size: 2000
    concurrency: 4
    queue_limit: 8
    cutoff:
      days_ago: 730
    delete:
      enabled: true
      batch_size: 2000
      sleep_ms: 0
      lag_days: 30
      strict_guard: true
      min_lag_days: 7
    objects:
      - key: archive_tb_workbussinessjsoninfo
        kind: workbusiness_json
        target_table: tb_workbussinessjsoninfo
        pk: Id
        enabled: true
        json_clean:
          column: BussinessJson
          keys: ["tireNeedOuterTireRemoval"]
      - key: archive_basic_resourceitem
        kind: basic_resourceitem
        target_table: basic_resourceitem
        pk: Id
        enabled: true

# 可选：与 pipelines 合并的额外定时任务
# schedule_set:
#   extra_job:
#     enabled: false
#     schedule: "0 6 * * *"
#     module: "structalert.tasks"
#     function: "run_daily_comparison"
